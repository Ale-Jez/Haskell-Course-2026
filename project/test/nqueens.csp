// 4-Queens Problem
// Place 4 queens on a 4x4 board so no two queens attack each other.
// Variables Q1..Q4 represent the ROW position of the queen in each COLUMN.
//
// Constraints encoded:
//   1. No two queens share the same row  -> allDifferent(Q1,Q2,Q3,Q4)
//   2. No two queens share a diagonal    -> |Qi - Qj| /= |i - j|
//
// Because the DSL does not support arithmetic expressions, diagonal
// constraints are NOT expressible in .csp syntax. They are instead
// enforced programmatically in the test suite (see EndToEndSpec.hs).
// This file encodes only the row-uniqueness constraint.

var Q1 : 1..4;
var Q2 : 1..4;
var Q3 : 1..4;
var Q4 : 1..4;

// No two queens in the same row
constraint allDifferent(Q1, Q2, Q3, Q4);
